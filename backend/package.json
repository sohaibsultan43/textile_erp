{
  "name": "textile-erp-backend",
  "version": "1.0.0",
  "description": "Backend API for Textile ERP System",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "build": "echo 'No build step required for Node.js'",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "node src/seed.js",
    "prisma:reset": "prisma migrate reset --force && npm run prisma:seed"
  },
  "dependencies": {
    "@prisma/client": "^5.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "prisma": "^5.6.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  },
  "keywords": [
    "textile",
    "erp",
    "api",
    "express",
    "postgresql"
  ],
  "author": "Textile ERP Team",
  "license": "MIT"
}
